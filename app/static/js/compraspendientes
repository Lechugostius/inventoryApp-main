// Compras Pendientes - Checklist
const PENDING_API_URL = '/api/pending-purchases';
const PENDING_MARK_URL = '/api/pending-purchases/mark';

async function loadPendingPurchases() {
    const container = document.getElementById('pending-purchases-container');
    if (!container) return;
    
    container.innerHTML = `
        <div class="pending-spinner">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2 text-muted">Cargando productos pendientes...</p>
        </div>
    `;
    
    try {
        const response = await fetch(PENDING_API_URL);
        const products = await response.json();
        
        if (products.error) {
            container.innerHTML = `
                <div class="pending-empty">
                    <i class="fas fa-exclamation-triangle"></i>
                    <p>Error: ${products.error}</p>
                </div>
            `;
            return;
        }
        
        if (products.length === 0) {
            container.innerHTML = `
                <div class="pending-empty">
                    <i class="fas fa-check-circle"></i>
                    <p>No hay productos pendientes</p>
                    <small>Todos los productos tienen stock suficiente</small>
                </div>
            `;
            return;
        }
        
        let html = '';
        for (let i = 0; i < products.length; i++) {
            const p = products[i];
            const isChecked = p.status === 'purchased';
            const badgeClass = isChecked ? 'badge-purchased' : 'badge-pending';
            const badgeText = isChecked ? 'Pedido realizado' : 'Critico - Pendiente';
            
            html += `
                <div class="pending-item" data-id="${p.id}">
                    <div class="pending-product-name">
                        <input type="checkbox" class="pending-checkbox" data-id="${p.id}" ${isChecked ? 'checked' : ''}>
                        <span>${escapeHtml(p.name)}</span>
                        <span class="${badgeClass}">${badgeText}</span>
                    </div>
                    <div class="pending-details">
                        Stock actual: ${p.stock} | Minimo: ${p.minimumStock} | Deficit: ${p.deficit}
                        <div class="pending-suggestion">
                            Sugerencia: Pedir ${p.deficit} unidades
                        </div>
                    </div>
                </div>
            `;
        }
        
        container.innerHTML = html;
        
        document.querySelectorAll('.pending-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', async function(e) {
                const productId = parseInt(this.getAttribute('data-id'));
                const newStatus = this.checked ? 'purchased' : 'pending';
                const itemDiv = this.closest('.pending-item');
                const badgeSpan = itemDiv.querySelector('.badge-pending, .badge-purchased');
                
                if (!this.checked) {
                    const confirmar = confirm('¿Estas seguro de quitar el check de este producto? El pedido se marcara como pendiente nuevamente.');
                    if (!confirmar) {
                        this.checked = true;
                        return;
                    }
                }
                
                this.disabled = true;
                
                try {
                    const response = await fetch(PENDING_MARK_URL, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId: productId, status: newStatus })
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        if (newStatus === 'purchased') {
                            badgeSpan.className = 'badge-purchased';
                            badgeSpan.innerText = 'Pedido realizado';
                        } else {
                            badgeSpan.className = 'badge-pending';
                            badgeSpan.innerText = 'Critico - Pendiente';
                        }
                    } else {
                        this.checked = !this.checked;
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    console.error('Error:', error);
                    this.checked = !this.checked;
                    alert('Error de conexion al servidor');
                } finally {
                    this.disabled = false;
                }
            });
        });
        
    } catch (error) {
        console.error('Error en loadPendingPurchases:', error);
        container.innerHTML = `
            <div class="pending-empty">
                <i class="fas fa-exclamation-triangle"></i>
                <p>Error al cargar los datos</p>
                <small>Intente recargar la pagina</small>
            </div>
        `;
    }
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

document.addEventListener('DOMContentLoaded', loadPendingPurchases);